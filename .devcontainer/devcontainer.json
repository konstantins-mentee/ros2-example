{
  "name": "ros2-example (Jazzy, arm64)",

  "image": "ros2-jazzy-arm64:dev",

  "runArgs": [
    "--platform=linux/arm64",
    "--network=host",
    "--ipc=host",
    "--name=ros2-example-devcontainer"
  ],

  "containerUser": "ros",
  "remoteUser": "ros",

  "containerEnv": {
    "ROS_DOMAIN_ID": "0"
  },

  "workspaceFolder": "/home/ros/ws/src/ros2-example",
  "workspaceMount": "source=${localWorkspaceFolder}/..,target=/home/ros/ws/src,type=bind,consistency=cached",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cmake-tools",
        "twxs.cmake",
        "ms-python.python",
        "ms-iot.vscode-ros"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "cmake.configureOnOpen": false,
        "C_Cpp.default.cppStandard": "c++17",
        "C_Cpp.default.intelliSenseMode": "linux-gcc-arm64",
        "C_Cpp.default.compilerPath": "/usr/bin/g++",
        "C_Cpp.default.includePath": [
          "${workspaceFolder}/**",
          "/opt/ros2_jazzy/install/**",
          "/home/ros/ws/install/**",
          "/usr/include/**"
        ],
        "ros.distro": "jazzy"
      }
    }
  }
}
